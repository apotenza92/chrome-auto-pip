{
  "name": "Automatic Picture-in-Picture (PiP)",
  "description": "Auto Picture-in-Picture when you switch tabs like Arc and Firefox, with one-click PiP from the toolbar.",
  "version": "1.7.0",
  "manifest_version": 3,
  "icons": {
    "128": "assets/icon.png"
  },
  "background": {
    "service_worker": "main.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "scripts/utils.js",
        "scripts/site-fixes.js",
        "scripts/trigger-auto-pip.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_title": "Picture-in-Picture",
    "default_icon": "assets/icon.png"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "permissions": [
    "scripting",
    "storage",
    "tabs",
    "activeTab",
    "contentSettings"
  ],
  "host_permissions": ["<all_urls>"],
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "minimum_chrome_version": "134",
  "author": "Alex Potenza",
  "homepage_url": "https://github.com/apotenza92/chrome-auto-pip"
}
